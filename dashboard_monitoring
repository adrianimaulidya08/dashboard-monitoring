// Vertikal bar section
function vBarSection(items, chartH) {
  chartH = chartH || 220;
  const maxV = Math.max(...items.map(x => x.val), 100);
  const scale = chartH / maxV;
  const yAxisW = 40;
  const gap = 4;
  const barW = Math.max(14, Math.min(46, Math.floor((540 - yAxisW - gap * items.length) / items.length)));

  const yAxis = `<div style="width:${yAxisW}px;flex-shrink:0;position:relative;height:${chartH}px;">
    ${[0,25,50,75,100].map(pct => {
      const bot = Math.round(pct * scale);
      return `<div style="position:absolute;bottom:${bot}px;right:5px;color:#8A9DB8;font-size:9px;font-weight:700;transform:translateY(50%);white-space:nowrap;line-height:1">${pct}%</div>`;
    }).join('')}
    <div style="position:absolute;top:0;bottom:-2px;right:0;border-right:2px solid #CBD5E1"></div>
  </div>`;

  const gridLines = [25,50,75,100].map(pct => {
    const bot = Math.round(pct * scale);
    return `<div style="position:absolute;bottom:${bot}px;left:0;right:0;border-top:1px dashed ${pct===100?'#2563EB30':'#E4EAF2'};pointer-events:none"></div>`;
  }).join('');

  const barEls = items.map(({val, color}) => {
    const h = Math.max(3, Math.round(val * scale));
    return `<div style="display:flex;flex-direction:column;align-items:center;justify-content:flex-end;width:${barW}px;height:${chartH}px;flex-shrink:0">
      <div style="color:${color};font-size:8px;font-weight:800;margin-bottom:2px;white-space:nowrap">${val.toFixed(1)}%</div>
      <div style="width:100%;height:${h}px;background:${color};border-radius:4px 4px 0 0;box-shadow:0 2px 5px ${color}55;flex-shrink:0"></div>
    </div>`;
  }).join('');

  const plotArea = `<div style="flex:1;position:relative;height:${chartH}px;border-bottom:2px solid #CBD5E1;overflow:visible;padding:0 6px">
    ${gridLines}
    <div style="display:flex;align-items:flex-end;gap:${gap}px;height:100%;position:absolute;bottom:0;left:6px;right:6px">${barEls}</div>
  </div>`;

  const xLabelEls = items.map(({label}) => {
    const words = label.split(' ');
    const shortLabel = words.length > 1 ? words[0] + '<br>' + words.slice(1).join(' ') : label;
    return `<div style="width:${barW}px;flex-shrink:0;text-align:center;color:#3D526B;font-size:8px;line-height:1.3">${shortLabel}</div>`;
  }).join('');

  return `<div style="padding:10px 0 0">
    <div style="display:flex;align-items:flex-end">${yAxis}${plotArea}</div>
    <div style="display:flex;gap:${gap}px;margin-left:${yAxisW}px;padding:5px 6px 0;box-sizing:border-box">${xLabelEls}</div>
  </div>`;
}


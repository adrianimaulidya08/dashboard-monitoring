</div>`;
}

// ── RENDER PAGE ke PDF ──
async function renderPageToPDF(doc, htmlContent, W, PW, PH, pageIdx) {
  const container = document.getElementById('pdf-render');
  container.style.cssText = `position:fixed;left:0;top:0;z-index:99999;width:${W}px;background:#F0F4F9;`;
  container.innerHTML = htmlContent;
  await new Promise(r => setTimeout(r, 400));
  const canvas = await html2canvas(container, {
    scale: 2, useCORS: true, allowTaint: true,
    width: W, height: container.scrollHeight,
    windowWidth: W, logging: false, backgroundColor: '#F0F4F9'
  });
  container.style.cssText = 'position:fixed;left:-9999px;top:0;z-index:-1;width:1122px;';
  container.innerHTML = '';
  const imgData = canvas.toDataURL('image/jpeg', 0.95);
  if (pageIdx > 0) doc.addPage();
  doc.addImage(imgData, 'JPEG', 0, 0, PW, PH);
}

// ══════════════════════════════════════════════════════════════
// MAIN DOWNLOAD PDF
// ══════════════════════════════════════════════════════════════
async function downloadPDF() {
  if (!filtered.length) return alert('Tidak ada data untuk diunduh. Coba ubah filter.');

  const btn = document.querySelector('button[onclick="downloadPDF()"]');
  if (btn) { btn.disabled = true; btn.innerHTML = '&#9203; Membuat PDF...'; }

  try {
    const { jsPDF } = window.jspdf;
    const now = new Date();
    const ts = `${now.getFullYear()}${String(now.getMonth()+1).padStart(2,'0')}${String(now.getDate()).padStart(2,'0')}`;
    const tgl = now.toLocaleDateString('id-ID', { day:'2-digit', month:'long', year:'numeric' }) +
                ' pukul ' + String(now.getHours()).padStart(2,'0') + '.' + String(now.getMinutes()).padStart(2,'0');

    const fTahunVal = document.getElementById('fTahun').value;
    const fKecRaw   = document.getElementById('fKec').value;
    const fKelVal   = document.getElementById('fKel').value;
    const fKatVal   = document.getElementById('fKat').value;

    const fTahun = fTahunVal || 'Semua';
    const fKec   = fKecRaw === '__KOTA_PALU__' ? 'Kota Palu' : (fKecRaw || 'Semua');
    const fKel   = fKelVal   || 'Semua';
    const fKat   = fKatVal   || 'Semua';

    // Ambil logo
    let logoSrc = '', logoSrc2 = '';
    try {
      const imgs = document.querySelectorAll('.sb-brand img');
      if (imgs[0]) logoSrc  = imgs[0].currentSrc || imgs[0].src;
      if (imgs[1]) logoSrc2 = imgs[1].currentSrc || imgs[1].src;
    } catch(e) {}

    const doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a4' });
    const PW = doc.internal.pageSize.getWidth();
    const PH = doc.internal.pageSize.getHeight();

    // Shared render fn
    const renderPage = async (html, idx) => renderPageToPDF(doc, html, W, PW, PH, idx);
    const wp = (content, pg, tot) => wrapPage(content, pg, tot, tgl, logoSrc, logoSrc2, fTahun, fKec, fKel, fKat);

    // Bangun kelRows dari filtered
    const kelRows = buildKelMap(filtered);

    // ════════════════════════════════════════════════════════
    // MODE 1: Filter Kelurahan spesifik → 1 halaman
    // ════════════════════════════════════════════════════════
    if (fKelVal) {
      const avg = calcAvgProg(kelRows);
      const catAvg = calcCatAvg(kelRows);
      const catItems = CAT_NAMES.map(cn => ({
        label: cn,
        val: catAvg[cn].cnt > 0 ? Math.round((catAvg[cn].sum / catAvg[cn].cnt) * 10) / 10 : 0,
        color: sColor(catAvg[cn].cnt > 0 ? catAvg[cn].sum / catAvg[cn].cnt : 0)
      }));

      // Ambil info kelurahan
      const kelInfo = kelRows[0] || {};
      const kecNama = kelInfo.kec || fKec;

      const content = `
<div style="text-align:center;margin-bottom:18px">
  <div style="display:inline-block;background:#1558A8;color:#fff;font-size:13px;font-weight:800;padding:10px 28px;border-radius:10px">
    ${fKelVal} — ${kecNama}${fTahunVal ? ' (' + fTahunVal + ')' : ''}
  </div>
</div>
${pieAndKatLayout(
  'Progres Kelurahan',
  `<b>${fKelVal}</b> | ${kecNama}`,
  avg,
  'Pie Chart',
  '#F47B20',
  catItems,
  260
)}`;

      await renderPage(wp(content, 1, 1), 0);
    }

    // ════════════════════════════════════════════════════════
    // MODE 2: Filter Kota Palu (fKecRaw === '__KOTA_PALU__')
    // Halaman 1: Pie + Kategori Kota Palu
    // Halaman 2–9: Pie + Kategori per Kecamatan
    // ════════════════════════════════════════════════════════
    else if (fKecRaw === '__KOTA_PALU__') {
      // Semua kecamatan dari allData (tidak difilter per kecamatan)
      const allKelRows = buildKelMap(allData.filter(d =>
        (!fTahunVal || d.tahun == fTahunVal) &&
        (!fKatVal || d.kategori === fKatVal)
      ));

      // Daftar kecamatan
      const kecNames = [...new Set(allKelRows.map(r => r.kec))].sort();
      const totalPages = 1 + kecNames.length;

      // Halaman 1: Kota Palu keseluruhan
      const kotaAvg = calcAvgProg(allKelRows);
      const kotaCatAvg = calcCatAvg(allKelRows);
      const kotaCatItems = CAT_NAMES.map(cn => ({
        label: cn,
        val: kotaCatAvg[cn].cnt > 0 ? Math.round((kotaCatAvg[cn].sum / kotaCatAvg[cn].cnt) * 10) / 10 : 0,
        color: sColor(kotaCatAvg[cn].cnt > 0 ? kotaCatAvg[cn].sum / kotaCatAvg[cn].cnt : 0)
      }));

      const page1 = `
<div style="text-align:center;margin-bottom:18px">
  <div style="display:inline-block;background:#C45800;color:#fff;font-size:14px;font-weight:800;padding:10px 28px;border-radius:10px">
    Kota Palu${fTahunVal ? ' (' + fTahunVal + ')' : ''}
  </div>
</div>
${pieAndKatLayout(
  'Progres Kota Palu',
  '',
  kotaAvg,
  'Pie Chart',
  '#C45800',
  kotaCatItems,
  280
)}`;
      await renderPage(wp(page1, 1, totalPages), 0);

      // Halaman 2–9: per kecamatan
      for (let ki = 0; ki < kecNames.length; ki++) {
        const kecName = kecNames[ki];
        const kecRows = allKelRows.filter(r => r.kec === kecName);
        const kecAvg = calcAvgProg(kecRows);
        const kecCatAvg = calcCatAvg(kecRows);
        const kecCatItems = CAT_NAMES.map(cn => ({
          label: cn,
          val: kecCatAvg[cn].cnt > 0 ? Math.round((kecCatAvg[cn].sum / kecCatAvg[cn].cnt) * 10) / 10 : 0,
          color: sColor(kecCatAvg[cn].cnt > 0 ? kecCatAvg[cn].sum / kecCatAvg[cn].cnt : 0)
        }));

        const pageContent = `
<div style="text-align:center;margin-bottom:18px">
  <div style="display:inline-block;background:#1558A8;color:#fff;font-size:14px;font-weight:800;padding:10px 28px;border-radius:10px">
    Kecamatan ${kecName}${fTahunVal ? ' (' + fTahunVal + ')' : ''}
  </div>
</div>
${pieAndKatLayout(
  'Progres Kecamatan ' + kecName,
  '',
  kecAvg,
  'Pie Chart',
  '#1558A8',
  kecCatItems,
  260
)}`;
        await renderPage(wp(pageContent, ki + 2, totalPages), ki + 1);
      }
    }

    // ════════════════════════════════════════════════════════
    // MODE 3: Semua kecamatan atau kecamatan tertentu (tanpa kelurahan spesifik)
    // Halaman 1: Pie + Kategori Kota Palu
    // Halaman 2–N: Pie kecamatan + bar kelurahan + kategori + tabel detail
    // ════════════════════════════════════════════════════════
    else {
      const kecNames = fKecRaw
        ? [fKecRaw]
        : [...new Set(kelRows.map(r => r.kec))].sort();

      const totalPages = 1 + kecNames.length;

      // Halaman 1: gambaran keseluruhan (semua dari filtered)
      const kotaAvg = calcAvgProg(kelRows);
      const kotaCatAvg = calcCatAvg(kelRows);
      const kotaCatItems = CAT_NAMES.map(cn => ({
        label: cn,
        val: kotaCatAvg[cn].cnt > 0 ? Math.round((kotaCatAvg[cn].sum / kotaCatAvg[cn].cnt) * 10) / 10 : 0,
        color: sColor(kotaCatAvg[cn].cnt > 0 ? kotaCatAvg[cn].sum / kotaCatAvg[cn].cnt : 0)
      }));
      const judulH1 = fKecRaw ? `Kecamatan ${fKecRaw}` : 'Kota Palu';

      const page1 = `
<div style="text-align:center;margin-bottom:18px">
  <div style="display:inline-block;background:#C45800;color:#fff;font-size:14px;font-weight:800;padding:10px 28px;border-radius:10px">
    ${judulH1}${fTahunVal ? ' (' + fTahunVal + ')' : ''}
  </div>
</div>
${pieAndKatLayout(
  'Progres ' + judulH1,
  '',
  kotaAvg,
  'Pie Chart',
  '#C45800',
  kotaCatItems,
  280
)}`;
      await renderPage(wp(page1, 1, totalPages), 0);

      // Halaman per kecamatan
      for (let ki = 0; ki < kecNames.length; ki++) {
        const kecName = kecNames[ki];
        const kecRows = kelRows.filter(r => r.kec === kecName);
        const kecAvg = calcAvgProg(kecRows);
        const kecCatAvg = calcCatAvg(kecRows);
        const kecCatItems = CAT_NAMES.map(cn => ({
          label: cn,
          val: kecCatAvg[cn].cnt > 0 ? Math.round((kecCatAvg[cn].sum / kecCatAvg[cn].cnt) * 10) / 10 : 0,
          color: sColor(kecCatAvg[cn].cnt > 0 ? kecCatAvg[cn].sum / kecCatAvg[cn].cnt : 0)
        }));

        // Bar kelurahan
        const kelGroupMap = {};
        for (const r of kecRows) {
          if (!kelGroupMap[r.kel]) kelGroupMap[r.kel] = { sum: 0, cnt: 0 };
          kelGroupMap[r.kel].sum += r.totalProg; kelGroupMap[r.kel].cnt++;
        }
        const kelBarItems = Object.keys(kelGroupMap).sort().map(kn => ({
          label: kn,
          val: Math.round((kelGroupMap[kn].sum / kelGroupMap[kn].cnt) * 10) / 10,
          color: sColor(kelGroupMap[kn].sum / kelGroupMap[kn].cnt)
        }));

        const pieSvg = buildPieSVG(kecAvg, 200, '', 'progres');
        const pieColor = sColor(kecAvg);

        const pageContent = `
<div style="text-align:center;margin-bottom:16px">
  <div style="display:inline-block;background:#1558A8;color:#fff;font-size:14px;font-weight:800;padding:10px 28px;border-radius:10px">
    Kecamatan ${kecName}${fTahunVal ? ' (' + fTahunVal + ')' : ''}
  </div>
</div>
<div style="display:grid;grid-template-columns:1fr 2fr 1fr;gap:16px;margin-bottom:16px">
  ${card('#F47B20', `
    ${cardTitle('Progres', `Kecamatan ${kecName}`, 'Pie Chart', '#F47B20')}
    <div style="display:flex;flex-direction:column;align-items:center;padding:4px 0">
      ${pieSvg}
      <div style="margin-top:12px;text-align:center">
        <div style="font-size:26px;font-weight:900;color:${pieColor};line-height:1">${kecAvg.toFixed(1)}%</div>
        <div style="font-size:11px;color:#8A9DB8;font-weight:600;margin-top:4px">Rata-rata Progres</div>
      </div>
      ${legendHtml()}
    </div>
  `)}
  ${card('#1558A8', `
    ${cardTitle('Progres per Kelurahan', `Kecamatan ${kecName}`, 'Diagram Batang', '#1558A8')}
    ${vBarSection(kelBarItems, 260)}
    ${legendHtml()}
  `)}
  ${card('#1E9E58', `
    ${cardTitle('Rata-rata per Kategori', `Kecamatan ${kecName}`, 'Horizontal Bar', '#1E9E58')}
    ${hBarSection(kecCatItems)}
  `)}
</div>
${tabelDetailHtml([...kecRows].sort((a,b) => a.kel.localeCompare(b.kel) || a.tahun - b.tahun), kecName)}`;

        await renderPage(wp(pageContent, ki + 2, totalPages), ki + 1);
      }
    }

    // Simpan PDF
    const namaFile = [
      'laporan_monev',
      fTahun !== 'Semua' ? fTahun : '',
      fKec !== 'Semua' ? fKec.replace(/\s+/g,'_') : '',
      fKel !== 'Semua' ? fKel.replace(/\s+/g,'_') : '',
      ts
    ].filter(Boolean).join('_');
    doc.save(namaFile + '.pdf');

  } finally {
    const btn = document.querySelector('button[onclick="downloadPDF()"]');
    if (btn) {
      btn.disabled = false;
      btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Download PDF';
    }
    const c = document.getElementById('pdf-render');
    if (c) { c.style.cssText = 'position:fixed;left:-9999px;top:0;z-index:-1;width:1122px;'; c.innerHTML = ''; }
  }
}


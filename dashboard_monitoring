function buildKecFilter() {
  const sel = document.getElementById('fKec');
  const kecs = [...new Set(allData.map(d => d.kec))].sort();
  sel.innerHTML =
    '<option value="">Semua Kecamatan</option>' +
    '<option value="__KOTA_PALU__">Kota Palu</option>' +
    kecs.map(k => `<option value="${k}">${k}</option>`).join('');
}

function onKecChange() {
  const kec = document.getElementById('fKec').value;
  const sel = document.getElementById('fKel');
  if (kec === '__KOTA_PALU__') {
    sel.innerHTML = '<option value="">Semua Kelurahan</option>';
    sel.disabled = true;
  } else if (kec) {
    sel.disabled = false;
    const kels = [...new Set(allData.filter(d => d.kec === kec).map(d => d.kel))].sort();
    sel.innerHTML = '<option value="">Semua Kelurahan</option>' +
      kels.map(k => `<option value="${k}">${k}</option>`).join('');
  } else {
    sel.disabled = false;
    sel.innerHTML = '<option value="">Semua Kelurahan</option>';
  }
  applyFilters();
}

function applyFilters() {
  const tahun = document.getElementById('fTahun').value;
  const kec   = document.getElementById('fKec').value;
  const kel   = document.getElementById('fKel').value;
  const kat   = document.getElementById('fKat').value;

  filtered = allData.filter(d =>
    (!tahun || d.tahun == tahun) &&
    (kec === '__KOTA_PALU__' || !kec || d.kec === kec) &&
    (!kel   || d.kel === kel) &&
    (!kat   || d.kategori === kat)
  );
  renderCharts();
}

function resetFilters() {
  ['fTahun','fKec','fKat'].forEach(id => document.getElementById(id).value = '');
  const selKel = document.getElementById('fKel');
  selKel.innerHTML = '<option value="">Semua Kelurahan</option>';
  selKel.value = '';
  selKel.disabled = false;
  applyFilters();
}


        <th style="padding:9px 12px;color:#fff;font-size:10px;text-align:left;border-right:1px solid rgba(255,255,255,.1);min-width:110px">Kelurahan</th>
        <th style="padding:9px 8px;color:#fff;font-size:10px;text-align:center;border-right:1px solid rgba(255,255,255,.1)">Thn</th>
        <th style="padding:9px 10px;color:#fff;font-size:10px;text-align:right;border-right:1px solid rgba(255,255,255,.1)">Pengisian</th>
        <th style="padding:9px 10px;color:#fff;font-size:10px;text-align:right;border-right:1px solid rgba(255,255,255,.1)">Target</th>
        <th style="padding:9px 8px;color:#fff;font-size:10px;text-align:center;border-right:1px solid rgba(255,255,255,.1);background:#7A3500">Total %</th>
        ${CAT_NAMES.map(cn => `<th style="padding:9px 5px;color:#FFD580;font-size:9px;font-weight:700;text-align:center;border-right:1px solid rgba(255,255,255,.07);white-space:nowrap">${cn}</th>`).join('')}
      </tr>

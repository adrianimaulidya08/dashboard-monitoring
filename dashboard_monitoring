<script>
// ── KONFIGURASI ──────────────────────────────────────────────
const SHEET_ID = '1lF4TFpI_rfwqirD_HAIYxZgPcPWANaRPVXZM9luLRt8';
const SHEETS = [
  { name:'Bantu Hitung 2024', year:2024 },
  { name:'Bantu Hitung 2025', year:2025 },
  { name:'Bantu Hitung 2026', year:2026 },
];

const CATS = [
  { name:'Umum',             p:6,  t:7,  g:8  },
  { name:'Sumber Daya Alam', p:9,  t:10, g:11 },
  { name:'Pemerintahan',     p:12, t:13, g:14 },
  { name:'Penduduk',         p:15, t:16, g:17 },
  { name:'Pendidikan',       p:18, t:19, g:20 },
  { name:'Kesehatan',        p:21, t:22, g:23 },
  { name:'Sosial',           p:24, t:25, g:26 },
  { name:'Ekonomi',          p:27, t:28, g:29 },
  { name:'Pertanian',        p:30, t:31, g:32 },
  { name:'Lingkungan',       p:33, t:34, g:35 },
];
const CAT_NAMES = CATS.map(c => c.name);

// ── STATE ─────────────────────────────────────────────────────
let allData = [], filtered = [];
let chKec = null, chKat = null;

// ── UTILS ─────────────────────────────────────────────────────
function progColor(v) {
  if (v >= 100) return '#16A34A';
  if (v >= 75)  return '#2563EB';
  if (v >= 50)  return '#EA580C';
  return '#DC2626';
}

function setSync() {
  const now = new Date();
  const hh = String(now.getHours()).padStart(2,'0');
  const mm = String(now.getMinutes()).padStart(2,'0');
  document.getElementById('lastSync').textContent = `Sinkron ${hh}:${mm}`;
  document.getElementById('syncDot').style.background = '#22c55e';
}

function showErr(msg) {
  const banner = document.getElementById('error-banner');
  document.getElementById('error-msg').textContent = msg;
  banner.style.display = 'block';
  document.getElementById('syncDot').style.background = '#e63946';
  document.getElementById('lastSync').textContent = 'Gagal memuat';
}

function toggleSidebar() {
  const isMobile = window.innerWidth <= 768;
  if (isMobile) {
    document.body.classList.toggle('sidebar-open');
  } else {
    document.body.classList.toggle('sidebar-collapsed');
    setTimeout(() => {
      if (chKec) chKec.resize();
      if (chKat) chKat.resize();
    }, 320);
  }
}

// ── FETCH ─────────────────────────────────────────────────────
async function fetchSheet(cfg) {
  const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${encodeURIComponent(cfg.name)}`;
  let res;
  try { res = await fetch(url); } catch(e) {
    throw new Error(`Tidak bisa terhubung ke internet atau Google Sheets diblokir. (${e.message})`);
  }
  if (!res.ok) throw new Error(`HTTP ${res.status} saat mengambil sheet "${cfg.name}".`);
  const txt = await res.text();
  const match = txt.match(/google\.visualization\.Query\.setResponse\(([\s\S]*?)\);?\s*$/);
  if (!match) throw new Error(`Format respons tidak valid dari sheet "${cfg.name}".`);
  const json = JSON.parse(match[1]);
  if (!json.table || !json.table.rows) throw new Error(`Sheet "${cfg.name}" kosong.`);

  const out = [];
  let lastKec = '';

  for (const row of json.table.rows) {
    if (!row?.c) continue;
    const c = row.c;
    const noRaw = c[0]?.v;
    if (noRaw === null || noRaw === undefined) continue;
    const noNum = parseFloat(noRaw);
    if (isNaN(noNum) || noNum <= 0) continue;
    const kel = c[2]?.v ? String(c[2].v).trim() : '';
    if (!kel) continue;
    if (['kelurahan','no','nama'].includes(kel.toLowerCase())) continue;
    const kecRaw = c[1]?.v ? String(c[1].v).trim() : '';
    if (kecRaw) lastKec = kecRaw;
    if (!lastKec) continue;

    const totalPeng = parseFloat(c[3]?.v) || 0;
    const totalTgt  = parseFloat(c[4]?.v) || 0;
    let totalProgRaw = parseFloat(c[5]?.v) || 0;
    const totalProg = totalProgRaw > 0 && totalProgRaw <= 1.5 ? totalProgRaw * 100 : totalProgRaw;

    for (const cat of CATS) {
      const peng = parseFloat(c[cat.p]?.v) || 0;
      const tgt  = parseFloat(c[cat.t]?.v) || 0;
      let progRaw = parseFloat(c[cat.g]?.v) || 0;
      const prog = progRaw > 0 && progRaw <= 1.5 ? progRaw * 100 : progRaw;
      out.push({
        kec: lastKec, kel, tahun: cfg.year,
        kategori: cat.name,
        pengisian: peng, target: tgt, progres: prog,
        totalPeng, totalTgt, totalProg, no: noNum
      });
    }
  }
  return out;
}

async function loadAllData() {
  const icon = document.getElementById('refreshIcon');
  icon.classList.add('spin');
  document.getElementById('loading').style.display = 'flex';
  document.getElementById('error-banner').style.display = 'none';
  document.querySelector('.loader-sub').textContent = 'Menghubungkan ke Google Sheets...';
  try {
    allData = [];
    for (const cfg of SHEETS) {
      document.querySelector('.loader-sub').textContent = `Mengambil: ${cfg.name}...`;
      allData = allData.concat(await fetchSheet(cfg));
    }
    if (allData.length === 0) {
      showErr('Data berhasil diambil tapi kosong.');
      return;
    }
    buildKecFilter();
    applyFilters();
    setSync();
    setTimeout(loadAllData, 5 * 60 * 1000);
  } catch(e) {
    showErr(e.message);
  } finally {
    document.getElementById('loading').style.display = 'none';
    icon.classList.remove('spin');
  }
}


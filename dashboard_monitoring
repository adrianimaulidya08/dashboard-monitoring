// ── Helper: bangun kelMap dari data ──
function buildKelMap(data) {
  const kelMap = new Map();
  for (const d of data) {
    const key = `${d.kec}||${d.kel}||${d.tahun}`;
    if (!kelMap.has(key)) kelMap.set(key, { kec: d.kec, kel: d.kel, tahun: d.tahun, totalPeng: d.totalPeng, totalTgt: d.totalTgt, totalProg: d.totalProg, cats: {} });
    kelMap.get(key).cats[d.kategori] = { peng: d.pengisian, tgt: d.target, prog: d.progres };
  }
  return [...kelMap.values()].sort((a,b) => a.kec.localeCompare(b.kec) || a.kel.localeCompare(b.kel) || a.tahun - b.tahun);
}

// ── Helper: hitung rata-rata progres dari kelRows ──
function calcAvgProg(rows) {
  if (!rows.length) return 0;
  return rows.reduce((s,r) => s + r.totalProg, 0) / rows.length;
}

// ── Helper: hitung rata-rata kategori dari kelRows ──
function calcCatAvg(rows) {
  const catAvg = {};
  for (const cn of CAT_NAMES) catAvg[cn] = { sum: 0, cnt: 0 };
  for (const r of rows) for (const cn of CAT_NAMES) { catAvg[cn].sum += r.cats[cn]?.prog || 0; catAvg[cn].cnt++; }
  return catAvg;
}

// ── Color helper untuk PDF ──
const sColor = v => v >= 100 ? '#1E9E58' : v >= 75 ? '#1558A8' : v >= 50 ? '#F47B20' : '#e63946';

// ─────────────────────────────────────────────────────────────
// SVG PIE CHART BUILDER
// v: nilai progres (0–100)
// size: ukuran SVG (px)
// label: teks di tengah
// ─────────────────────────────────────────────────────────────
function buildPieSVG(v, size, label, subLabel) {
  const pct = Math.min(Math.max(v, 0), 100);
  const color = sColor(v);
  const bg = '#E4EAF2';
  const cx = size / 2, cy = size / 2;
  const r = size * 0.38;
  const stroke = size * 0.12;
  const circumference = 2 * Math.PI * r;
  const dashArray = (pct / 100) * circumference;
  const dashOffset = circumference * 0.25; // mulai dari atas

  // Arc path untuk pie (lebih estetik dengan stroke-dasharray pada circle)
  const mainFontSize = Math.round(size * 0.14);
  const subFontSize = Math.round(size * 0.065);
  const labelFontSize = Math.round(size * 0.07);

  return `<svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <filter id="shadow-${Math.round(v*10)}" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="${color}" flood-opacity="0.25"/>
    </filter>
  </defs>
  <!-- Background ring -->
  <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${bg}" stroke-width="${stroke}"/>
  <!-- Progress ring -->
  <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${color}" stroke-width="${stroke}"
    stroke-dasharray="${dashArray} ${circumference}"
    stroke-dashoffset="-${dashOffset}"
    stroke-linecap="round"
    filter="url(#shadow-${Math.round(v*10)})"
    transform="rotate(-90 ${cx} ${cy})"/>
  <!-- Center text: persen -->
  <text x="${cx}" y="${cy - subFontSize * 0.3}" text-anchor="middle" dominant-baseline="middle"
    font-family="'Segoe UI',Arial,sans-serif" font-size="${mainFontSize}" font-weight="900" fill="${color}">${pct.toFixed(1)}%</text>
  ${subLabel ? `<text x="${cx}" y="${cy + mainFontSize * 0.7}" text-anchor="middle" dominant-baseline="middle"
    font-family="'Segoe UI',Arial,sans-serif" font-size="${subFontSize}" font-weight="600" fill="#8A9DB8">${subLabel}</text>` : ''}
  ${label ? `<text x="${cx}" y="${size - labelFontSize * 0.8}" text-anchor="middle" dominant-baseline="middle"
    font-family="'Segoe UI',Arial,sans-serif" font-size="${labelFontSize}" font-weight="700" fill="#3D526B">${label}</text>` : ''}
</svg>`;
}


  return `<div style="background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.06);margin-top:16px">
  <div style="background:linear-gradient(90deg,#7A3500,#A84A00);padding:12px 20px">
